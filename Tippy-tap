// Decay slider
function decayLabel(v){
  if(v<=0.4) return 'Stays forever ✨';
  if(v<=0.8) return 'Lingers long 🌙';
  if(v<=1.4) return 'Normal fade';
  if(v<=2.5) return 'Fades quickly ⚡';
  return 'Instant pop 💥';
}
decaySlider.addEventListener('input',()=>{
  decayMultiplier=parseFloat(decaySlider.value);
  decayHint.textContent=decayLabel(decayMultiplier);
});
decaySlider.addEventListener('touchstart',e=>e.stopPropagation(),{passive:true});
decaySlider.addEventListener('touchmove', e=>e.stopPropagation(),{passive:true});

// Play area touches
document.addEventListener('touchstart',e=>{
  if(!active)return;
  if(hud.contains(e.target)||settingsTray.contains(e.target))return;
  e.preventDefault();
  settingsTray.classList.remove('open');
  Array.from(e.changedTouches).forEach(t=>handleTouch(t.clientX,t.clientY));
},{passive:false});

document.addEventListener('touchmove',e=>{
  if(!active)return;
  if(settingsTray.contains(e.target))return;
  e.preventDefault();
  if(Math.random()<0.35) Array.from(e.changedTouches).forEach(t=>handleTouch(t.clientX,t.clientY));
},{passive:false});

document.addEventListener('click',e=>{
  if(!active)return;
  if(hud.contains(e.target)||settingsTray.contains(e.target))return;
  handleTouch(e.clientX,e.clientY);
});

document.addEventListener('contextmenu',e=>e.preventDefault());
document.addEventListener('gesturestart',e=>e.preventDefault());
document.addEventListener('gesturechange',e=>e.preventDefault());
</script>

</body>
</html>
