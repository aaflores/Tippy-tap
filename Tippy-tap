let activeEmojiCat=Object.keys(EMOJI_CATS)[0];
function buildEmojiTabs(){
  const tabsEl=document.getElementById('emoji-tabs');
  Object.keys(EMOJI_CATS).forEach(cat=>{
    const t=document.createElement('div');
    t.className='emoji-tab'+(cat===activeEmojiCat?' active':'');
    t.textContent=cat;
    t.addEventListener('click',()=>{
      activeEmojiCat=cat;
      tabsEl.querySelectorAll('.emoji-tab').forEach(x=>x.classList.remove('active'));
      t.classList.add('active');
      renderEmojiGrid();
    });
    tabsEl.appendChild(t);
  });
}

function renderEmojiGrid(){
  const grid=document.getElementById('emoji-grid');
  grid.innerHTML='';
  EMOJI_CATS[activeEmojiCat].forEach(em=>{
    const btn=document.createElement('div');
    btn.className='emoji-btn'+(customSelectedEmojis.has(em)?' selected':'');
    btn.textContent=em;
    btn.addEventListener('click',()=>{
      if(customSelectedEmojis.has(em)){
        customSelectedEmojis.delete(em);
        btn.classList.remove('selected');
      } else {
        if(customSelectedEmojis.size>=MAX_CUSTOM_EMOJIS) return;
        customSelectedEmojis.add(em);
        btn.classList.add('selected');
      }
      renderSelectedPreview();
    });
    grid.appendChild(btn);
  });
}

function renderSelectedPreview(){
  const preview=document.getElementById('selected-preview');
  preview.innerHTML='';
  if(customSelectedEmojis.size===0){
    const lbl=document.createElement('span');lbl.className='preview-label';
    lbl.textContent='None selected yet — tap some above!';
    preview.appendChild(lbl);
  } else {
    customSelectedEmojis.forEach(em=>{
      const chip=document.createElement('div');chip.className='preview-chip';chip.textContent=em;
      chip.title='Tap to remove';
      chip.addEventListener('click',()=>{
        customSelectedEmojis.delete(em);
        // deselect in grid if visible
        document.querySelectorAll('.emoji-btn').forEach(b=>{if(b.textContent===em)b.classList.remove('selected');});
        renderSelectedPreview();
      });
      preview.appendChild(chip);
    });
  }
  startCustomBtn.disabled=customSelectedEmojis.size===0;
}

function buildCustomScene(){
  const bg=BG_COLORS[customBgIndex];
  const emojis=[...customSelectedEmojis];
  // Generate particle colors from the bg hue + bright accents
  const colors=['#ff6eb4','#ffd166','#06d6a0','#a78bfa','#ff9de2','#48cae4','#f87171','#34d399'].slice(0,6);
  SCENES['custom']={
    canvasFade:bg.fade,
    particleColors:colors,
    flashBg:'rgba(255,255,255,0.15)',
    emojis,
    shapeTypes:['circle','star','heart','triangle','square'],
    rippleColor:'#e040fb',
    soundType:['sine','triangle','square'],soundFreqScale:1.0,
    ambientFn:()=>buildEmojiAmbient(emojis,20,8,14),
