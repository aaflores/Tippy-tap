function handleTouch(x,y){
  if(!active||!currentScene)return;
  const sc=SCENES[currentScene];initAudio();
  tapCount++;score+=Math.floor(Math.random()*10)+5;
  tapEl.textContent=tapCount;scoreEl.textContent=score;
  playNote(x,sc);
  spawnParticles(x,y,sc.particleColors,18);
  spawnRipple(x,y,sc.rippleColor);
  flashBg(sc);
  const ns=Math.floor(Math.random()*3)+2;
  for(let i=0;i<ns;i++) setTimeout(()=>spawnShape(x+(Math.random()-.5)*60,y+(Math.random()-.5)*60,sc),i*55);
  if(Math.random()<0.5) spawnEmoji(x,y,sc);
  if(tapCount%10===0) bigCelebration(sc);
}

function bigCelebration(sc){
  showMilestone(sc);
  for(let i=0;i<50;i++){
    const rx=Math.random()*innerWidth,ry=Math.random()*innerHeight;
    setTimeout(()=>{spawnParticles(rx,ry,sc.particleColors,8);if(Math.random()<0.4)spawnShape(rx,ry,sc);},i*40);
  }
}

