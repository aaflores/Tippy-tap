    el.className='color-swatch'+(i===customBgIndex?' selected':'');
    el.style.background=c.hex;
    el.title=c.label;
    el.addEventListener('click',()=>{
      customBgIndex=i;
      container.querySelectorAll('.color-swatch').forEach((s,j)=>s.classList.toggle('selected',j===i));
    });
