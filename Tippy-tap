}

function enterScene(key){
  const sc=SCENES[key];
  currentScene=key;
  document.body.className=key;
  document.body.style.background=sc.bgGradient||sc.bgHex;
  showScreen(null); // hide all screens
  hud.style.display='flex';
  mstone.style.fontFamily=`'${sc.font}',sans-serif`;
  sc.ambientFn();
  particles=[];ctx2d.clearRect(0,0,canvas.width,canvas.height);
  active=true;initAudio();
}

function goToMenu(){
  active=false;currentScene=null;
  tapCount=0;score=0;tapEl.textContent='0';scoreEl.textContent='0';
  hud.style.display='none';settingsTray.classList.remove('open');
  showScreen('scene-select');
  particles=[];clearAmbient();
  document.querySelectorAll('.fx,.ripple-ring').forEach(e=>e.remove());
  ctx2d.clearRect(0,0,canvas.width,canvas.height);
  document.body.style.background='';
}

