function spawnParticles(x,y,colors,count=20){
  for(let i=0;i<count;i++) particles.push(new Particle(x,y,colors[Math.floor(Math.random()*colors.length)]));
}

function spawnShape(x,y,scene){
  const el=document.createElement('div');el.className='fx';
  const type=scene.shapeTypes[Math.floor(Math.random()*scene.shapeTypes.length)];
  const size=Math.random()*55+28;
  const color=scene.particleColors[Math.floor(Math.random()*scene.particleColors.length)];
  if(type==='circle'){
    el.style.cssText=`width:${size}px;height:${size}px;border-radius:50%;background:${color};filter:drop-shadow(0 0 10px ${color});`;
  }else if(type==='square'||type==='diamond'){
    el.style.cssText=`width:${size}px;height:${size}px;border-radius:8px;background:${color};filter:drop-shadow(0 0 10px ${color});transform:rotate(${type==='diamond'?45:Math.random()*30}deg);`;
  }else if(type==='triangle'){
    el.style.cssText=`width:0;height:0;border-left:${size/2}px solid transparent;border-right:${size/2}px solid transparent;border-bottom:${size}px solid ${color};filter:drop-shadow(0 0 10px ${color});`;
  }else{
    const map={star:'⭐',heart:'❤️',leaf:'🍃',bubble:'🫧',wave:'〰️',footprint:'🐾'};
    el.style.cssText=`font-size:${size}px;line-height:1;filter:drop-shadow(0 0 8px ${color});`;
    el.textContent=map[type]||'●';
  }
  el.style.left=`${x-size/2}px`;el.style.top=`${y-size/2}px`;
  document.body.appendChild(el);
  const vx=(Math.random()-.5)*180,vy=-Math.random()*320-60,rot=(Math.random()-.5)*600;
  const dur=800+Math.random()*600,t0=performance.now();
  let velY=vy,px=x-size/2,py=y-size/2,angle=0,prevT=t0;
  (function anim(now){
    const dt=(now-prevT)/1000;prevT=now;
    velY+=820*dt;px+=vx*dt;py+=velY*dt;angle+=rot*dt;
    const prog=Math.min(1,(now-t0)/dur);
    el.style.left=`${px}px`;el.style.top=`${py}px`;
    el.style.transform=`rotate(${angle}deg)`;el.style.opacity=1-prog*prog;
    prog<1?requestAnimationFrame(anim):el.remove();
  })(t0);
}

function spawnEmoji(x,y,scene){
  const el=document.createElement('div');el.className='fx';
  el.style.cssText=`font-size:clamp(34px,10vw,68px);font-weight:900;left:${x}px;top:${y}px;transform:translate(-50%,-50%) scale(0);`;
  el.textContent=scene.emojis[Math.floor(Math.random()*scene.emojis.length)];
  document.body.appendChild(el);
  const dur=700,t0=performance.now();
  (function anim(now){
    const t=Math.min(1,(now-t0)/dur);
    const scale=t<0.3?t/0.3*1.5:1.5-(t-0.3)/0.7*1.5;
    el.style.top=`${y-120*t}px`;
    el.style.transform=`translate(-50%,-50%) scale(${scale})`;
    el.style.opacity=1-t*t;
    t<1?requestAnimationFrame(anim):el.remove();
  })(t0);
}

function spawnRipple(x,y,color){
  const el=document.createElement('div');el.className='ripple-ring';
  el.style.cssText=`left:${x}px;top:${y}px;width:50px;height:50px;margin-left:-25px;margin-top:-25px;border-color:${color};`;
  document.body.appendChild(el);setTimeout(()=>el.remove(),700);
}

function flashBg(scene){
  document.body.style.transition='background .05s';
  document.body.style.background=scene.flashBg;
