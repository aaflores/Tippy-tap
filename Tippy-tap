class Particle{
  constructor(x,y,color){
    this.x=x;this.y=y;
    this.vx=(Math.random()-.5)*16;this.vy=(Math.random()-.5)*16;
    this.alpha=1;this.r=Math.random()*10+4;this.color=color;
    this.gravity=0.38;this.baseDecay=0.018+Math.random()*0.014;
  }
  update(){
    this.x+=this.vx;this.y+=this.vy;this.vy+=this.gravity;
    this.vx*=0.98;this.alpha-=this.baseDecay*decayMultiplier;this.r*=0.97;
  }
  draw(){
    ctx2d.save();ctx2d.globalAlpha=Math.max(0,this.alpha);
    ctx2d.fillStyle=this.color;ctx2d.shadowColor=this.color;ctx2d.shadowBlur=14;
    ctx2d.beginPath();ctx2d.arc(this.x,this.y,Math.max(0,this.r),0,Math.PI*2);
    ctx2d.fill();ctx2d.restore();
  }
}

function renderLoop(){
  if(currentScene && SCENES[currentScene]){
    ctx2d.fillStyle=SCENES[currentScene].canvasFade;
    ctx2d.fillRect(0,0,canvas.width,canvas.height);
  } else {
    ctx2d.clearRect(0,0,canvas.width,canvas.height);
  }
  particles=particles.filter(p=>p.alpha>0.01);
  particles.forEach(p=>{p.update();p.draw();});
  requestAnimationFrame(renderLoop);
}
renderLoop();

