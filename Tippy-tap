function initAudio(){if(audioCtx)return;audioCtx=new(window.AudioContext||window.webkitAudioContext)();}
const SCALE=[261.63,293.66,329.63,349.23,392,440,493.88,523.25,587.33,659.25,698.46,783.99,880];

function playNote(x,scene){
  if(!audioCtx||!scene)return;
  try{
    const gain=audioCtx.createGain(),osc=audioCtx.createOscillator(),filt=audioCtx.createBiquadFilter();
    const freq=SCALE[Math.floor((x/innerWidth)*SCALE.length)]*scene.soundFreqScale;
    osc.type=scene.soundType[Math.floor(Math.random()*scene.soundType.length)];
    osc.frequency.setValueAtTime(freq,audioCtx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(freq*1.4,audioCtx.currentTime+0.12);
    filt.type='bandpass';filt.frequency.value=freq*2;filt.Q.value=3;
    gain.gain.setValueAtTime(0.2,audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+0.45);
    osc.connect(filt);filt.connect(gain);gain.connect(audioCtx.destination);
    osc.start();osc.stop(audioCtx.currentTime+0.5);
  }catch(e){}
}

